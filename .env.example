# Syncology environment — copy to .env (gitignored) and fill in locally.
# NEVER commit real keys. .env and .env.* are gitignored (except this .example).

# --- Data locations (local, gitignored) ---
# Root of raw personal data. Override if your data lives elsewhere.
SYNCOLOGY_DATA_DIR=data
# DuckDB warehouse file (gitignored via *.duckdb).
SYNCOLOGY_DUCKDB_PATH=data/clean/syncology.duckdb

# --- LLM extraction (used from A1 lab-PDF step onward, not the parser) ---
# Prefer a cheap model for bulk extraction; note cost in the write-up.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
